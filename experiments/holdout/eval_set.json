{
  "name": "mantis-holdout-v1",
  "description": "Typed holdout for the slow-loop champion/challenger gate. Tasks are chosen to be representative of real-world CUA capability TYPES (login, scrape, search, form_fill, crud_create, crud_edit, upload/export, navigate) rather than one site. Each task is grounded in a real sim-env oracle (deterministic /__env__/oracle grading), so success is ground-truth, not transcript-judged. Split: train on `visible` (seed 42), evaluate the gate on `sealed` (seed 7) — sealed tasks are never trained on.",
  "splits": {"visible_seed": 42, "sealed_seed": 7},
  "grading": "Each task is graded by its env oracle (GET /__env__/oracle?task_id=<oracle_task_id>); criterion task_success reflects that verdict. The runner stands up `env` (Daytona/Modal), seeds it for the task's split, drives `task_text` from `start_path`, then reads the oracle.",
  "tasks": [
    {"task_id": "auth.T01_password_login", "task_text": "Sign in with the given username and password.", "url": "", "criteria": [{"type": "task_success"}], "metadata": {"type": "login", "env": "mantis_auth", "oracle_task_id": "T01_password_login", "start_path": "/login", "split": "sealed"}},
