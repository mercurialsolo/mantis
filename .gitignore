# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# Virtual environments
.venv*/

# Environment & secrets
.env
.env.*
*.pem
*.key
credentials*.json
secrets*.json

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project-specific
.codex_tmp/
OSWorld/
*.gguf
*.qcow2
logs/
cache/
results/
outputs/
reports/
screenshots/

# Local MANTIS_DATA_DIR fallback. Without explicit override, the runner
# (and the Augur adapter from #509) writes per-run state under ./data/.
# Always machine-local; never committed.
data/

# Run output artifacts (CSVs at repo root); CSVs under tasks/ and plans/ stay tracked
/leads_*.csv
/boattrader_leads*.csv

# Claude
.claude/
site/

# Customer-specific plan / task files — never commit. The generic recipes
# in docs/integrations/recipes.md are the public surface; customer-specific
# workflow JSON belongs in private operator storage, not in this repo.
plans/
tasks/
internal-docs/
# Test-only plans (often contain throwaway credentials for staging
# tenants — do NOT commit). Keep generic, public-target examples in
# `examples/` instead.
tests/plans/

# VisualWebArena upstream — clone next to the repo when running the
# benchmarking conversion script. Never commit; would re-introduce the
# orphan-submodule pip-install bug.
VWA_configs/

# Local text-plan benchmark reports — generated by scripts/analyze_text_plan_run.py.
# Stored locally only; never committed.
reports/

# Personal in-progress design notes and CUA debugger drafts. Kept in the
# working tree for reference but never committed; promote to docs/ via a
# normal PR when ready.
docs/cua_design.md
docs/cua_notes.md
docs/cua-debugger-spec.md
docs/experiments/staff-crm-long-learnings.md

# Local adhoc submission / probe / verify harnesses. These tend to
# hardcode customer-named target URLs, seed lead IDs, and proxy creds
# — they must NOT land in the repo (per
# feedback_no_customer_names_in_tracked_files + the no-adhoc-scripts
# rule). The shipped submission surface is the mantis CLI; adhoc
# scripts stay local. Match anything under scripts/ that looks like
# a run-with-flags helper.
scripts/run_*_with_proxy.py
scripts/run_*_no_proxy.py
scripts/run_staff_crm_long_no_proxy.py
