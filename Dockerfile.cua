# CUA Agent container — Xvfb + xdotool + Chromium (no Playwright)
# Matches the Vision Claude architecture:
#   Xvfb → Openbox → Chromium → xdotool → screenshot → brain → repeat
#
# Build:  docker build -f Dockerfile.cua -t mantis-cua .
# Run:    docker run --rm -e BRAIN_URL=https://your-brain/v1 mantis-cua \
#           --task-file tasks/boattrader/full_production.json

FROM python:3.11-slim

# System deps: virtual display + window manager + input tools + browser
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    openbox \
    xdotool \
    scrot \
    chromium \
    fonts-liberation fonts-noto-color-emoji \
    libnss3 libatk-bridge2.0-0 libdrm2 libxkbcommon0 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 libxshmfence1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python deps (minimal — no playwright)
COPY pyproject.toml ./
RUN pip install --no-cache-dir \
    requests pillow openai mss

# Copy source
COPY src/ ./src/
COPY run_local.py ./
COPY tasks/ ./tasks/
COPY plans/ ./plans/

# Startup script: Xvfb + openbox + agent
COPY docker_entrypoint.sh ./
RUN chmod +x docker_entrypoint.sh

ENTRYPOINT ["./docker_entrypoint.sh"]
CMD ["--task-file", "tasks/boattrader/full_production.json"]
