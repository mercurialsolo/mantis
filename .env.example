# Mantis CUA Agent — Environment Variables
# Copy to .env and fill in your values

# ── Anthropic — required for Claude grounding + extraction ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Mantis container auth ──
# X-Mantis-Token enforced by baseten_server.py. Generate any random string.
MANTIS_API_TOKEN=your_random_mantis_token

# ── Proxy (optional — for residential geo / Cloudflare bypass) ──
# IPRoyal residential proxy: https://iproyal.com/residential-proxies/
PROXY_URL=http://geo.iproyal.com:12321
PROXY_USER=your_iproyal_username
PROXY_PASS=your_iproyal_password_country-us

# ── Hosting providers (set the ones you deploy to) ──
# Baseten gateway API key (only needed when fronting via Baseten)
BASETEN_API_KEY=your_baseten_api_key
# Modal: deploy via `modal deploy`; secrets read from this file via from_dotenv()
